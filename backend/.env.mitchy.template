# Mitchy provider order. Try every provider before final fallback.
# Recommended for now: Groq first, Gemini second, OpenRouter third, xAI/Grok fourth.
MITCHY_PROVIDER_ORDER=groq,gemini,openrouter,xai
MITCHY_PROVIDER_TIMEOUT_SECONDS=20
MITCHY_PROVIDER_MAX_TOKENS=900
MITCHY_PROVIDER_TEMPERATURE=0.25
MITCHY_HTTP_USER_AGENT=LearNova-Mitchy/1.0

# Generic OpenAI-compatible provider switch.
# Use provider name "primary" in MITCHY_PROVIDER_ORDER to activate this.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=20

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=LearNova Mitchy

# xAI / Grok
XAI_API_KEY=
XAI_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions

# Document chunks retrieval
# Keep global retrieval disabled by default because the KB includes noisy transcripts.
# Topic-page retrieval still works when topic_id is provided.
MITCHY_DOCUMENT_RETRIEVAL_ENABLED=true
MITCHY_DOCUMENT_RETRIEVAL_GLOBAL_ENABLED=false
MITCHY_DOCUMENT_RETRIEVAL_LIMIT=5
MITCHY_DOCUMENT_RETRIEVAL_TOPIC_MIN_SCORE=1
MITCHY_DOCUMENT_RETRIEVAL_GLOBAL_MIN_SCORE=6

# Recommended order when GitHub Models is available
MITCHY_PROVIDER_ORDER=github,groq,gemini,openrouter,xai
MITCHY_PROVIDER_TIMEOUT_SECONDS=25
MITCHY_PROVIDER_MAX_TOKENS=1000
MITCHY_PROVIDER_TEMPERATURE=0.2

GITHUB_MODELS_API_KEY=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODEL=openai/gpt-5-mini
