# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Railway service auth
SCORING_API_KEY=change-this-scoring-secret
MITCHY_SERVICE_API_KEY=change-this-mitchy-secret

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=12

# Mitchy DB-first retrieval
MITCHY_DOCUMENT_RETRIEVAL_ENABLED=true
MITCHY_DOCUMENT_RETRIEVAL_LIMIT=5
MITCHY_DOCUMENT_RETRIEVAL_MIN_SCORE=1

# Backup provider order after Gemini fails
# Supported values: groq, openrouter, xai
# You can also write grok; the code maps it to xai.
MITCHY_PROVIDER_ORDER=groq,openrouter,xai
MITCHY_PROVIDER_TIMEOUT_SECONDS=12

# Groq backup provider
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter backup provider
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=https://learnova.app
OPENROUTER_APP_NAME=LearNova Mitchy

# xAI/Grok backup provider
XAI_API_KEY=YOUR_XAI_OR_GROK_API_KEY
XAI_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions